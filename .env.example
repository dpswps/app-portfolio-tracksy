# ─────────────────────────────────────────────────────────────
# 환경변수 템플릿. 이 파일은 git에 커밋됨 (실제 키는 절대 적지 말 것).
# 실제 사용 시: 이 파일을 복사해서 `.env.local` 로 저장하고 값을 채워넣은 뒤
# `npm run dev` 재시작.
# ─────────────────────────────────────────────────────────────

# Groq API 키 (필수)
# /api/chat (AI 러닝일지) 와 /api/ocr (캡쳐사진 스캔) 양쪽에서 사용.
# 발급: https://console.groq.com → API Keys → Create API Key
GROQ_API_KEY=

# (선택) 비전 모델 override — 비워두면 기본값(llama-4-scout-17b)
# GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ─────────────────────────────────────────────────────────────
# Supabase (인증·DB·Storage)
# Supabase 대시보드 → Project Settings → API 에서 확인.
# ─────────────────────────────────────────────────────────────

# 프로젝트 URL (예: https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# anon public 키 (브라우저에서 사용. RLS 정책으로 보호됨)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service role 키 (서버 전용. RLS 우회. 절대 브라우저에 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=
